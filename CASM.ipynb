    "    \"# ─── 4. REQUIRES_VERIFICATION ────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_dosage_requires_verification_true():\\n\",\n",
    "    \"    \\\"\\\"\\\"DOSAGE_CLAIM: requires_verification = True.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: requires_verification — DOSAGE_CLAIM ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Prescribe Glipizide 5mg daily for blood sugar control.\\\")\\n\",\n",
    "    \"    dosage = [c for c in claims if c.claim_type == ClaimType.DOSAGE_CLAIM]\\n\",\n",
    "    \"    if dosage:\\n\",\n",
