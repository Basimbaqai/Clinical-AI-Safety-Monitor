    "    \"# ─── 3. ENTITY EXTRACTION ─────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_drug_name_extracted():\\n\",\n",
    "    \"    \\\"\\\"\\\"Drug names extracted from sentence.\\\"\\\"\\\"\\n\",\n",
