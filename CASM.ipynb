    "    \"        print(f\\\"  requires_verification: True ✓ PASS\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"  No DRUG_INTERACTION extracted ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_procedural_requires_verification_false():\\n\",\n",
    "    \"    \\\"\\\"\\\"PROCEDURAL_CLAIM: requires_verification = False.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: requires_verification — PROCEDURAL_CLAIM = False ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Monitor blood pressure every week during dose titration.\\\")\\n\",\n",
    "    \"    procedural = [c for c in claims if c.claim_type == ClaimType.PROCEDURAL_CLAIM]\\n\",\n",
    "    \"    if procedural:\\n\",\n",
    "    \"        assert procedural[0].requires_verification is False\\n\",\n",
    "    \"        print(f\\\"  requires_verification: False ✓ PASS\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"  No PROCEDURAL_CLAIM extracted ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── 5. ARCHITECTURE CONTRACTS ───────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_extract_signature_no_patient_context():\\n\",\n",
    "    \"    \\\"\\\"\\\"extract() must NOT accept patient_context — belongs to verifier.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: extract() signature — no patient_context ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    sig = inspect.signature(e.extract)\\n\",\n",
    "    \"    params = list(sig.parameters.keys())\\n\",\n",
    "    \"    assert \\\"patient_context\\\" not in params, \\\\\\n\",\n",
    "    \"        f\\\"patient_context should not be in extract() params: {params}\\\"\\n\",\n",
    "    \"    assert \\\"llm_response\\\" in params\\n\",\n",
    "    \"    print(f\\\"  Parameters: {params} ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_claim_has_no_population_flags_field():\\n\",\n",
    "    \"    \\\"\\\"\\\"Claim dataclass must not have population_flags field.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Claim has no population_flags field ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Prescribe Metformin 500mg daily.\\\")\\n\",\n",
    "    \"    if claims:\\n\",\n",
    "    \"        assert not hasattr(claims[0], \\\"population_flags\\\"), \\\\\\n\",\n",
    "    \"            \\\"population_flags must not exist on Claim — belongs to verifier\\\"\\n\",\n",
    "    \"    print(\\\"  No population_flags field on Claim ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_confidence_defaults_to_zero():\\n\",\n",
    "    \"    \\\"\\\"\\\"Confidence must be 0.0 — filled by Confidence Calibrator later.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: confidence defaults to 0.0 ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Prescribe Metformin 1000mg twice daily.\\\")\\n\",\n",
    "    \"    for c in claims:\\n\",\n",
    "    \"        assert c.confidence == 0.0, f\\\"Expected 0.0, got {c.confidence}\\\"\\n\",\n",
    "    \"    print(\\\"  confidence = 0.0 ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_claim_ids_sequential():\\n\",\n",
    "    \"    \\\"\\\"\\\"Claim IDs should follow claim_0, claim_1, claim_2 format.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Claim IDs are sequential ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\n\",\n",
    "    \"        \\\"Prescribe Metformin 500mg daily. \\\"\\n\",\n",
    "    \"        \\\"Avoid NSAIDs in kidney disease. \\\"\\n\",\n",
    "    \"        \\\"Monitor creatinine every 3 months.\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    for claim in claims:\\n\",\n",
    "    \"        assert claim.claim_id.startswith(\\\"claim_\\\"), f\\\"Bad ID format: {claim.claim_id}\\\"\\n\",\n",
    "    \"    print(f\\\"  IDs: {[c.claim_id for c in claims]} ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── 6. SERIALISATION ────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_extract_as_dict_json_serialisable():\\n\",\n",
    "    \"    \\\"\\\"\\\"extract_as_dict() output must be fully JSON serialisable.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: extract_as_dict() is JSON serialisable ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    result = e.extract_as_dict(\\\"Prescribe Metformin 1000mg daily. Avoid NSAIDs in CKD.\\\")\\n\",\n",
    "    \"    json_str = json.dumps(result)\\n\",\n",
    "    \"    parsed = json.loads(json_str)\\n\",\n",
    "    \"    assert isinstance(parsed, list) and len(parsed) > 0\\n\",\n",
    "    \"    print(f\\\"  Serialised {len(parsed)} claims ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_dict_has_all_required_keys():\\n\",\n",
    "    \"    \\\"\\\"\\\"Claim dict must have all 9 required keys.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Dict has all required keys ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    result = e.extract_as_dict(\\\"Prescribe Metformin 500mg twice daily.\\\")\\n\",\n",
    "    \"    required = {\\n\",\n",
    "    \"        \\\"claim_id\\\", \\\"claim_text\\\", \\\"claim_type\\\", \\\"entities\\\",\\n\",\n",
    "    \"        \\\"drug_names\\\", \\\"dosages\\\", \\\"conditions\\\",\\n\",\n",
    "    \"        \\\"requires_verification\\\", \\\"confidence\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    for claim in result:\\n\",\n",
    "    \"        missing = required - set(claim.keys())\\n\",\n",
    "    \"        assert not missing, f\\\"Missing keys: {missing}\\\"\\n\",\n",
    "    \"    print(f\\\"  All 9 keys present ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_dict_has_no_population_flags_key():\\n\",\n",
    "    \"    \\\"\\\"\\\"Claim dict must NOT have population_flags key.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Dict has no population_flags key ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    result = e.extract_as_dict(\\\"Prescribe Metformin 1000mg daily.\\\")\\n\",\n",
    "    \"    for claim in result:\\n\",\n",
    "    \"        assert \\\"population_flags\\\" not in claim, \\\\\\n\",\n",
    "    \"            \\\"population_flags must not be in claim dict — belongs to verifier\\\"\\n\",\n",
    "    \"    print(\\\"  No population_flags in dict ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_claim_type_is_string_not_enum():\\n\",\n",
    "    \"    \\\"\\\"\\\"claim_type in dict must be a plain string, not an Enum object.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: claim_type is string in dict ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    result = e.extract_as_dict(\\\"Prescribe Metformin 500mg twice daily.\\\")\\n\",\n",
    "    \"    if result:\\n\",\n",
    "    \"        assert isinstance(result[0][\\\"claim_type\\\"], str), \\\\\\n\",\n",
    "    \"            f\\\"Expected str, got {type(result[0]['claim_type'])}\\\"\\n\",\n",
    "    \"    print(\\\"  claim_type is str ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_entities_are_list_of_dicts():\\n\",\n",
    "    \"    \\\"\\\"\\\"entities in dict must be a list of dicts with text and label.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: entities format in dict ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    result = e.extract_as_dict(\\\"Prescribe Metformin 500mg for Type 2 Diabetes.\\\")\\n\",\n",
    "    \"    if result:\\n\",\n",
    "    \"        entities = result[0][\\\"entities\\\"]\\n\",\n",
    "    \"        assert isinstance(entities, list)\\n\",\n",
    "    \"        for ent in entities:\\n\",\n",
    "    \"            assert \\\"text\\\" in ent and \\\"label\\\" in ent\\n\",\n",
    "    \"    print(\\\"  entities format correct ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── 7. CORE CASM SCENARIO ───────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_core_casm_scenario():\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    THE MAIN TEST.\\n\",\n",
    "    \"    72yo diabetic CKD patient on Warfarin.\\n\",\n",
    "    \"    Validates all 4 dangerous claims are extracted correctly.\\n\",\n",
    "    \"    Population flags NOT tested here — that is the verifier's job.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n\\\" + \\\"═\\\" * 58)\\n\",\n",
    "    \"    print(\\\"  CORE TEST: 72yo CKD Diabetic on Warfarin\\\")\\n\",\n",
    "    \"    print(\\\"═\\\" * 58)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    llm_response = (\\n\",\n",
    "    \"        \\\"For blood sugar control, prescribe Metformin 1000mg twice daily. \\\"\\n\",\n",
    "    \"        \\\"For pain management, Ibuprofen 400mg three times daily is appropriate. \\\"\\n\",\n",
    "    \"        \\\"Add Glipizide 5mg daily to quickly bring down HbA1c. \\\"\\n\",\n",
    "    \"        \\\"Monitor kidney function every 6 months.\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    claims = e.extract(llm_response)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"\\\\n  Input: {llm_response}\\\\n\\\")\\n\",\n",
    "    \"    print(f\\\"  Extracted {len(claims)} claims:\\\\n\\\")\\n\",\n",
    "    \"    for c in claims:\\n\",\n",
    "    \"        marker = \\\"⚠️  VERIFY\\\" if c.requires_verification else \\\"✓  ok\\\"\\n\",\n",
    "    \"        print(f\\\"  [{c.claim_id}] {c.claim_type.value}\\\")\\n\",\n",
    "    \"        print(f\\\"         Text:    {c.claim_text}\\\")\\n\",\n",
    "    \"        print(f\\\"         Drugs:   {c.drug_names}\\\")\\n\",\n",
    "    \"        print(f\\\"         Dosages: {c.dosages}\\\")\\n\",\n",
    "    \"        print(f\\\"         Status:  {marker}\\\")\\n\",\n",
    "    \"        print()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Core assertions\\n\",\n",
    "    \"    assert len(claims) >= 3, f\\\"Expected ≥3 claims, got {len(claims)}\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    needs_verify = [c for c in claims if c.requires_verification]\\n\",\n",
    "    \"    assert len(needs_verify) >= 2, \\\\\\n\",\n",
    "    \"        f\\\"Expected ≥2 claims requiring verification, got {len(needs_verify)}\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    assert all(c.confidence == 0.0 for c in claims), \\\\\\n\",\n",
    "    \"        \\\"All confidence scores should be 0.0 at extraction stage\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    assert not any(hasattr(c, \\\"population_flags\\\") for c in claims), \\\\\\n\",\n",
    "    \"        \\\"population_flags must not exist on Claim at extraction stage\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"  ✓ {len(claims)} claims extracted\\\")\\n\",\n",
    "    \"    print(f\\\"  ✓ {len(needs_verify)} require verification\\\")\\n\",\n",
    "    \"    print(f\\\"  ✓ confidence = 0.0 on all\\\")\\n\",\n",
    "    \"    print(f\\\"  ✓ no population_flags on claims\\\")\\n\",\n",
    "    \"    print(\\\"  ✓ CORE TEST PASSED\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
