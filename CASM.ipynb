    "    \"        print(f\\\"  requires_verification: True ✓ PASS\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"  No DOSAGE_CLAIM extracted (model-dependent) ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_drug_safety_requires_verification_true():\\n\",\n",
    "    \"    \\\"\\\"\\\"DRUG_SAFETY_CLAIM: requires_verification = True.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: requires_verification — DRUG_SAFETY_CLAIM ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Avoid Ibuprofen in patients with renal failure.\\\")\\n\",\n",
    "    \"    safety = [c for c in claims if c.claim_type == ClaimType.DRUG_SAFETY_CLAIM]\\n\",\n",
    "    \"    if safety:\\n\",\n",
    "    \"        assert safety[0].requires_verification is True\\n\",\n",
    "    \"        print(f\\\"  requires_verification: True ✓ PASS\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"  No DRUG_SAFETY_CLAIM extracted ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_interaction_requires_verification_true():\\n\",\n",
    "    \"    \\\"\\\"\\\"DRUG_INTERACTION: requires_verification = True.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: requires_verification — DRUG_INTERACTION ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Warfarin and Aspirin concurrent use increases bleeding risk.\\\")\\n\",\n",
    "    \"    interaction = [c for c in claims if c.claim_type == ClaimType.DRUG_INTERACTION]\\n\",\n",
    "    \"    if interaction:\\n\",\n",
