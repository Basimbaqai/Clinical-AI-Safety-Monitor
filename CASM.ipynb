    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Claim Extractor\",\n",
    "   \"id\": \"31b6a3d97cddc419\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-12T03:56:44.970585800Z\",\n",
    "     \"start_time\": \"2026-03-12T03:56:44.943097Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"CASM — Claim Extractor\\n\",\n",
    "    \"======================\\n\",\n",
    "    \"Stage 1 of the CASM pipeline.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Single responsibility: convert a raw LLM clinical response\\n\",\n",
    "    \"into a list of structured, typed, entity-tagged atomic claims.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Does NOT handle patient context or population flags.\\n\",\n",
    "    \"Those are handled downstream by the Knowledge Verifier.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Install:\\n\",\n",
    "    \"    pip install spacy scispacy\\n\",\n",
    "    \"    pip install https://s3-us-west-2.amazonaws.com/ai2-s2-scispacy/releases/v0.5.4/en_core_sci_md-0.5.4.tar.gz\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"import spacy\\n\",\n",
    "    \"from dataclasses import dataclass\\n\",\n",
    "    \"from enum import Enum\\n\",\n",
    "    \"from typing import Optional\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── Enums ────────────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"class ClaimType(str, Enum):\\n\",\n",
    "    \"    DOSAGE_CLAIM      = \\\"DOSAGE_CLAIM\\\"\\n\",\n",
    "    \"    DRUG_SAFETY_CLAIM = \\\"DRUG_SAFETY_CLAIM\\\"\\n\",\n",
    "    \"    DRUG_INTERACTION  = \\\"DRUG_INTERACTION\\\"\\n\",\n",
    "    \"    PROCEDURAL_CLAIM  = \\\"PROCEDURAL_CLAIM\\\"\\n\",\n",
    "    \"    DIAGNOSIS_CLAIM   = \\\"DIAGNOSIS_CLAIM\\\"\\n\",\n",
    "    \"    POPULATION_CLAIM  = \\\"POPULATION_CLAIM\\\"\\n\",\n",
    "    \"    GENERAL_MEDICAL   = \\\"GENERAL_MEDICAL\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── Data Classes ─────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class Entity:\\n\",\n",
    "    \"    text: str\\n\",\n",
    "    \"    label: str    # spaCy entity label e.g. CHEMICAL, DISEASE, DOSAGE\\n\",\n",
    "    \"    start: int    # character offset in sentence\\n\",\n",
    "    \"    end: int\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"@dataclass\\n\",\n",
    "    \"class Claim:\\n\",\n",
    "    \"    claim_id:              str\\n\",\n",
    "    \"    claim_text:            str\\n\",\n",
    "    \"    claim_type:            ClaimType\\n\",\n",
    "    \"    entities:              list[Entity]\\n\",\n",
    "    \"    drug_names:            list[str]   # extracted drug/chemical names\\n\",\n",
    "    \"    dosages:               list[str]   # extracted dose values e.g. \\\"1000mg\\\"\\n\",\n",
    "    \"    conditions:            list[str]   # extracted disease/condition names\\n\",\n",
    "    \"    requires_verification: bool        # True for dosage/drug safety/interaction claims\\n\",\n",
    "    \"    confidence:            float       # placeholder — filled by Confidence Calibrator later\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── Keyword Maps ─────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"CLAIM_TYPE_KEYWORDS: dict[ClaimType, list[str]] = {\\n\",\n",
    "    \"    ClaimType.DOSAGE_CLAIM: [\\n\",\n",
    "    \"        \\\"mg\\\", \\\"mcg\\\", \\\"ml\\\", \\\"dose\\\", \\\"dosage\\\", \\\"twice\\\", \\\"once\\\", \\\"three times\\\",\\n\",\n",
    "    \"        \\\"daily\\\", \\\"bid\\\", \\\"tid\\\", \\\"qid\\\", \\\"weekly\\\", \\\"monthly\\\", \\\"prescribe\\\",\\n\",\n",
    "    \"        \\\"administer\\\", \\\"give\\\", \\\"start\\\", \\\"initiate\\\", \\\"tablet\\\", \\\"capsule\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    ClaimType.DRUG_SAFETY_CLAIM: [\\n\",\n",
    "    \"        \\\"avoid\\\", \\\"contraindicated\\\", \\\"do not use\\\", \\\"caution\\\", \\\"warning\\\",\\n\",\n",
    "    \"        \\\"unsafe\\\", \\\"dangerous\\\", \\\"harmful\\\", \\\"risk\\\", \\\"adverse\\\", \\\"side effect\\\",\\n\",\n",
    "    \"        \\\"toxicity\\\", \\\"nephrotoxic\\\", \\\"hepatotoxic\\\", \\\"cardiotoxic\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    ClaimType.DRUG_INTERACTION: [\\n\",\n",
    "    \"        \\\"interaction\\\", \\\"interacts\\\", \\\"combined with\\\", \\\"together with\\\",\\n\",\n",
    "    \"        \\\"concurrent\\\", \\\"concomitant\\\", \\\"potentiates\\\", \\\"inhibits\\\", \\\"induces\\\",\\n\",\n",
    "    \"        \\\"bleeding risk\\\", \\\"increased risk when\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    ClaimType.PROCEDURAL_CLAIM: [\\n\",\n",
    "    \"        \\\"monitor\\\", \\\"check\\\", \\\"test\\\", \\\"measure\\\", \\\"assess\\\", \\\"every\\\", \\\"weeks\\\",\\n\",\n",
    "    \"        \\\"months\\\", \\\"follow up\\\", \\\"review\\\", \\\"screen\\\", \\\"scan\\\", \\\"blood test\\\",\\n\",\n",
    "    \"        \\\"lab\\\", \\\"hba1c\\\", \\\"creatinine\\\", \\\"egfr\\\", \\\"blood pressure\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    ClaimType.DIAGNOSIS_CLAIM: [\\n\",\n",
    "    \"        \\\"diagnosis\\\", \\\"diagnose\\\", \\\"patient has\\\", \\\"presents with\\\", \\\"suffering from\\\",\\n\",\n",
    "    \"        \\\"consistent with\\\", \\\"indicative of\\\", \\\"suggests\\\", \\\"confirms\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    ClaimType.POPULATION_CLAIM: [\\n\",\n",
    "    \"        \\\"elderly\\\", \\\"pediatric\\\", \\\"children\\\", \\\"pregnant\\\", \\\"renal\\\", \\\"kidney\\\",\\n\",\n",
    "    \"        \\\"hepatic\\\", \\\"liver\\\", \\\"geriatric\\\", \\\"neonatal\\\", \\\"trimester\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Conjunctions that can hide multiple claims inside one sentence\\n\",\n",
    "    \"SPLIT_CONJUNCTIONS = [\\n\",\n",
    "    \"    r\\\"\\\\band also\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\badditionally\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\bfurthermore\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\bin addition\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\bmoreover\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\bhowever\\\\b\\\",\\n\",\n",
    "    \"    r\\\"\\\\balternatively\\\\b\\\",\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── Extractor ────────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"class ClaimExtractor:\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Converts a raw LLM clinical response into structured atomic claims.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Usage:\\n\",\n",
    "    \"        extractor = ClaimExtractor()\\n\",\n",
    "    \"        claims = extractor.extract(\\\"Prescribe Metformin 1000mg twice daily.\\\")\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __init__(self, model: str = \\\"en_core_sci_md\\\"):\\n\",\n",
    "    \"        print(f\\\"[ClaimExtractor] Loading model: {model}\\\")\\n\",\n",
    "    \"        self.nlp = spacy.load(model)\\n\",\n",
    "    \"        print(f\\\"[ClaimExtractor] Ready.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Public ────────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def extract(self, llm_response: str) -> list[Claim]:\\n\",\n",
    "    \"        \\\"\\\"\\\"\\n\",\n",
    "    \"        Takes raw LLM response text.\\n\",\n",
    "    \"        Returns list of Claim objects.\\n\",\n",
    "    \"        No patient context — that is the verifier's job.\\n\",\n",
    "    \"        \\\"\\\"\\\"\\n\",\n",
    "    \"        sentences = self._split_into_sentences(llm_response)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        claims = []\\n\",\n",
    "    \"        for idx, sentence in enumerate(sentences):\\n\",\n",
    "    \"            if not sentence.strip():\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"            claim = self._process_sentence(sentence, idx)\\n\",\n",
    "    \"            if claim:\\n\",\n",
    "    \"                claims.append(claim)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"[ClaimExtractor] {len(claims)} claims extracted.\\\")\\n\",\n",
    "    \"        return claims\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def extract_as_dict(self, llm_response: str) -> list[dict]:\\n\",\n",
    "    \"        \\\"\\\"\\\"Same as extract() but returns JSON-serialisable dicts.\\\"\\\"\\\"\\n\",\n",
    "    \"        return [self._to_dict(c) for c in self.extract(llm_response)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Sentence Splitting ────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _split_into_sentences(self, text: str) -> list[str]:\\n\",\n",
    "    \"        # Primary: spaCy sentence boundary detection\\n\",\n",
    "    \"        doc = self.nlp(text)\\n\",\n",
    "    \"        sentences = [sent.text.strip() for sent in doc.sents]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Secondary: split compound sentences on conjunctions\\n\",\n",
    "    \"        final = []\\n\",\n",
    "    \"        for sentence in sentences:\\n\",\n",
    "    \"            final.extend(self._split_on_conjunctions(sentence))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Drop fragments shorter than 4 words\\n\",\n",
    "    \"        return [s for s in final if len(s.split()) >= 4]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _split_on_conjunctions(self, sentence: str) -> list[str]:\\n\",\n",
    "    \"        parts = [sentence]\\n\",\n",
    "    \"        for pattern in SPLIT_CONJUNCTIONS:\\n\",\n",
    "    \"            new_parts = []\\n\",\n",
    "    \"            for part in parts:\\n\",\n",
    "    \"                split = re.split(pattern, part, flags=re.IGNORECASE)\\n\",\n",
    "    \"                new_parts.extend([s.strip() for s in split if s.strip()])\\n\",\n",
    "    \"            parts = new_parts\\n\",\n",
    "    \"        return parts\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Claim Processing ──────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _process_sentence(self, sentence: str, idx: int) -> Optional[Claim]:\\n\",\n",
    "    \"        doc = self.nlp(sentence)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        entities = [\\n\",\n",
    "    \"            Entity(text=ent.text, label=ent.label_,\\n\",\n",
    "    \"                   start=ent.start_char, end=ent.end_char)\\n\",\n",
    "    \"            for ent in doc.ents\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        drug_names = self._extract_drugs(entities, sentence)\\n\",\n",
    "    \"        dosages    = self._extract_dosages(entities, sentence)\\n\",\n",
    "    \"        conditions = self._extract_conditions(entities, sentence)\\n\",\n",
    "    \"        claim_type = self._classify_claim_type(sentence, entities)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Drop sentences with no medical content at all\\n\",\n",
    "    \"        if claim_type == ClaimType.GENERAL_MEDICAL and not entities:\\n\",\n",
    "    \"            return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        requires_verification = claim_type in [\\n\",\n",
    "    \"            ClaimType.DOSAGE_CLAIM,\\n\",\n",
    "    \"            ClaimType.DRUG_SAFETY_CLAIM,\\n\",\n",
    "    \"            ClaimType.DRUG_INTERACTION,\\n\",\n",
    "    \"            ClaimType.POPULATION_CLAIM,\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return Claim(\\n\",\n",
    "    \"            claim_id=f\\\"claim_{idx}\\\",\\n\",\n",
    "    \"            claim_text=sentence,\\n\",\n",
    "    \"            claim_type=claim_type,\\n\",\n",
    "    \"            entities=entities,\\n\",\n",
    "    \"            drug_names=drug_names,\\n\",\n",
    "    \"            dosages=dosages,\\n\",\n",
    "    \"            conditions=conditions,\\n\",\n",
    "    \"            requires_verification=requires_verification,\\n\",\n",
    "    \"            confidence=0.0,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Claim Type Classification ─────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _classify_claim_type(self, sentence: str, entities: list[Entity]) -> ClaimType:\\n\",\n",
    "    \"        sentence_lower = sentence.lower()\\n\",\n",
    "    \"        scores: dict[ClaimType, int] = {ct: 0 for ct in ClaimType}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for claim_type, keywords in CLAIM_TYPE_KEYWORDS.items():\\n\",\n",
    "    \"            for keyword in keywords:\\n\",\n",
    "    \"                if keyword in sentence_lower:\\n\",\n",
    "    \"                    scores[claim_type] += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        best = max(scores, key=lambda ct: scores[ct])\\n\",\n",
    "    \"        return best if scores[best] > 0 else ClaimType.GENERAL_MEDICAL\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Entity Extraction ─────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _extract_drugs(self, entities: list[Entity], sentence: str) -> list[str]:\\n\",\n",
    "    \"        drugs = [e.text for e in entities if e.label in {\\\"CHEMICAL\\\", \\\"DRUG\\\", \\\"MEDICATION\\\"}]\\n\",\n",
    "    \"        regex = re.findall(r'\\\\b[A-Z][a-z]+(?:in|ol|ine|ide|ate|mab|nib|pril|sartan|statin)\\\\b', sentence)\\n\",\n",
    "    \"        for d in regex:\\n\",\n",
    "    \"            if d not in drugs:\\n\",\n",
    "    \"                drugs.append(d)\\n\",\n",
    "    \"        return list(set(drugs))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _extract_dosages(self, entities: list[Entity], sentence: str) -> list[str]:\\n\",\n",
    "    \"        dosages = [e.text for e in entities if e.label in {\\\"DOSAGE\\\", \\\"QUANTITY\\\", \\\"CARDINAL\\\"}]\\n\",\n",
    "    \"        regex = re.findall(r'\\\\b\\\\d+(?:\\\\.\\\\d+)?\\\\s*(?:mg|mcg|ml|g|units?|IU|mmol)\\\\b', sentence, re.IGNORECASE)\\n\",\n",
    "    \"        for d in regex:\\n\",\n",
    "    \"            if d.strip() not in dosages:\\n\",\n",
    "    \"                dosages.append(d.strip())\\n\",\n",
    "    \"        return list(set(dosages))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _extract_conditions(self, entities: list[Entity], sentence: str) -> list[str]:\\n\",\n",
    "    \"        conditions = [e.text for e in entities if e.label in {\\\"DISEASE\\\", \\\"CONDITION\\\", \\\"DISORDER\\\"}]\\n\",\n",
    "    \"        abbrevs = re.findall(r'\\\\b(?:CKD|DM|T2DM|HTN|CAD|CHF|COPD|AF|DVT|PE|UTI)\\\\b', sentence)\\n\",\n",
    "    \"        for a in abbrevs:\\n\",\n",
    "    \"            if a not in conditions:\\n\",\n",
    "    \"                conditions.append(a)\\n\",\n",
    "    \"        return list(set(conditions))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ── Serialisation ─────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _to_dict(self, claim: Claim) -> dict:\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"claim_id\\\":              claim.claim_id,\\n\",\n",
    "    \"            \\\"claim_text\\\":            claim.claim_text,\\n\",\n",
    "    \"            \\\"claim_type\\\":            claim.claim_type.value,\\n\",\n",
    "    \"            \\\"entities\\\":              [{\\\"text\\\": e.text, \\\"label\\\": e.label} for e in claim.entities],\\n\",\n",
    "    \"            \\\"drug_names\\\":            claim.drug_names,\\n\",\n",
    "    \"            \\\"dosages\\\":               claim.dosages,\\n\",\n",
    "    \"            \\\"conditions\\\":            claim.conditions,\\n\",\n",
    "    \"            \\\"requires_verification\\\": claim.requires_verification,\\n\",\n",
    "    \"            \\\"confidence\\\":            claim.confidence,\\n\",\n",
    "    \"        }\"\n",
    "   ],\n",
    "   \"id\": \"6729409dd7b00621\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 6\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"## Claim Extractor Test Suite\",\n",
    "   \"id\": \"5452d8a56131c47c\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-12T04:12:22.550283600Z\",\n",
    "     \"start_time\": \"2026-03-12T04:12:22.116663600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"CASM — Claim Extractor Test Suite\\n\",\n",
    "    \"==================================\\n\",\n",
    "    \"Tests for extractor.py (clean version — no population flags).\\n\",\n",
    "    \"\\n\",\n",
    "    \"Run:\\n\",\n",
    "    \"    python test_extractor.py\\n\",\n",
    "    \"    pytest test_extractor.py -v\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import inspect\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── Setup ────────────────────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def get_extractor():\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        return ClaimExtractor(\\\"en_core_sci_md\\\")\\n\",\n",
    "    \"    except OSError:\\n\",\n",
    "    \"        print(\\\"[TEST] Falling back to en_core_web_sm\\\")\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            return ClaimExtractor(\\\"en_core_web_sm\\\")\\n\",\n",
    "    \"        except OSError:\\n\",\n",
    "    \"            print(\\\"[TEST] No spaCy model found.\\\")\\n\",\n",
    "    \"            print(\\\"[TEST] Run: python -m spacy download en_core_web_sm\\\")\\n\",\n",
    "    \"            sys.exit(1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ─── 1. SENTENCE SPLITTING ────────────────────────────────────────────────────\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_single_sentence():\\n\",\n",
    "    \"    \\\"\\\"\\\"Single sentence produces one claim.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Single sentence ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\\"Prescribe Metformin 1000mg twice daily.\\\")\\n\",\n",
    "    \"    assert len(claims) >= 1, f\\\"Expected 1 claim, got {len(claims)}\\\"\\n\",\n",
    "    \"    print(f\\\"  Claims: {len(claims)} ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_multiple_sentences():\\n\",\n",
    "    \"    \\\"\\\"\\\"Three separate sentences produce multiple claims.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Multiple sentences ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\n\",\n",
    "    \"        \\\"Prescribe Metformin 1000mg twice daily. \\\"\\n\",\n",
    "    \"        \\\"Avoid Ibuprofen in CKD patients. \\\"\\n\",\n",
    "    \"        \\\"Monitor HbA1c every 3 months.\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    assert len(claims) >= 2, f\\\"Expected at least 2 claims, got {len(claims)}\\\"\\n\",\n",
    "    \"    print(f\\\"  Claims: {len(claims)} ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_conjunction_split_additionally():\\n\",\n",
    "    \"    \\\"\\\"\\\"'Additionally' inside a sentence splits it into two claims.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n─── TEST: Conjunction split — additionally ───\\\")\\n\",\n",
    "    \"    e = get_extractor()\\n\",\n",
    "    \"    claims = e.extract(\\n\",\n",
    "    \"        \\\"Prescribe Metformin 1000mg daily. \\\"\\n\",\n",
    "    \"        \\\"Additionally monitor kidney function every 3 months.\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    assert len(claims) >= 2, f\\\"Expected at least 2 claims, got {len(claims)}\\\"\\n\",\n",
    "    \"    print(f\\\"  Claims: {len(claims)} ✓ PASS\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def test_conjunction_split_furthermore():\\n\",\n",
    "    \"    \\\"\\\"\\\"'Furthermore' splits correctly.\\\"\\\"\\\"\\n\",\n",
